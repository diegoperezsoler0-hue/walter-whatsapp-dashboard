# Dashboard API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_ANON_KEY=<anon-key-if-needed>
SUPABASE_SERVICE_ROLE_KEY=<never-commit-real-value>

# Dashboard Basic Auth
WALTER_DASHBOARD_USER=<user>
WALTER_DASHBOARD_PASS=<password>

# GeeLark
GEELARK_BASE_URL=https://openapi.geelark.com
GEELARK_BEARER_TOKEN=<never-commit-real-value>
GEELARK_GROUP_KEY=roma_toni

# Google Sheets / Workspace
GOOGLE_SHEETS_SPREADSHEET_ID=<spreadsheet-id>
GOOGLE_APPLICATION_CREDENTIALS=/absolute/local/path/not-in-repo/google-service-account.json

# Worker
WALTER_CAMPAIGN_WORKER_INTERVAL_SECONDS=120
GLOBAL_PAUSE_MIN_SECONDS=180
GLOBAL_PAUSE_MAX_SECONDS=360
MAX_SENDS_PER_DEVICE_PER_DAY=10
